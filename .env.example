# ─────────────────────────────────────────────────────────────────────────────
#  R-Group Analysis Suite — Environment Configuration
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#  Or run ./setup.sh to have it configured interactively.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key (get yours at https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ────────────────────────────────────────────────────────

# Claude model to use (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# FastAPI server host/port (defaults shown)
# API_HOST=0.0.0.0
# API_PORT=8000

# Log level: debug | info | warning | error (default: info)
# LOG_LEVEL=info
